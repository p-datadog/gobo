<% provide(:title, 'Memory (Fast)') %>
<h1>Memory Stats (Fast) <small><%= link_to "JSON", memory_fast_path(format: :json) %> | <%= link_to "Full View", memory_path %></small></h1>

<p class="text-muted">C-level only — uses <code>GC.stat</code> + <code>ObjectSpace.count_objects</code>. Safe with DI probes on hot methods.</p>

<div class="panel panel-default">
  <div class="panel-heading"><h4 class="panel-title">Process</h4></div>
  <div class="panel-body" style="padding: 10px 15px;">
    <p><strong>RSS:</strong> <%= @stats[:rss_mb] %> MB | <strong>Heap live slots:</strong> <%= number_with_delimiter(@stats[:heap_live_slots]) %> | <strong>Free slots:</strong> <%= number_with_delimiter(@stats[:heap_free_slots]) %></p>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">GC</h4></div>
      <div class="panel-body text-center">
        <p><strong>Total:</strong> <%= @stats[:gc_count] %> (<%= @stats[:major_gc_count] %> major / <%= @stats[:minor_gc_count] %> minor)</p>
        <p><strong>Allocated:</strong> <%= number_with_delimiter(@stats[:total_allocated_objects]) %> | <strong>Freed:</strong> <%= number_with_delimiter(@stats[:total_freed_objects]) %></p>
        <p><strong>malloc_increase:</strong> <%= number_with_delimiter(@stats[:malloc_increase_bytes]) %> | <strong>oldmalloc_increase:</strong> <%= number_with_delimiter(@stats[:oldmalloc_increase_bytes]) %></p>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">Objects by Type</h4></div>
      <table class="table table-condensed">
        <thead><tr><th>Type</th><th class="text-right">Count</th></tr></thead>
        <tbody>
          <% @stats[:count_objects].sort_by { |_k, v| -v }.each do |type, count| %>
            <% next if count == 0 %>
            <tr><td><code><%= type %></code></td><td class="text-right"><%= number_with_delimiter(count) %></td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="well">
  <button id="btn-gc" class="btn btn-warning">Force GC (3x full)</button>
  <button id="btn-trim" class="btn btn-info" style="margin-left: 10px;">malloc_trim</button>
  <button id="btn-refresh" class="btn btn-default" style="margin-left: 10px;">Refresh</button>
  <div id="action-result" class="alert alert-info" style="margin-top: 15px;">Click a button to run a memory action.</div>
</div>

<script>
  function formatBytes(bytes) {
    var abs = Math.abs(bytes);
    var sign = bytes < 0 ? '-' : '';
    if (abs >= 1048576) return sign + (abs / 1048576).toFixed(1) + ' MB';
    if (abs >= 1024) return sign + (abs / 1024).toFixed(1) + ' KB';
    return sign + abs + ' B';
  }

  function doAction(url, label) {
    var resultEl = document.getElementById('action-result');
    resultEl.className = 'alert alert-info';
    resultEl.innerHTML = '<strong>' + label + ':</strong> Running...';

    fetch(url, {method: 'POST', headers: {'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content}})
      .then(function(res) {
        if (!res.ok) {
          return res.text().then(function(text) { throw new Error('HTTP ' + res.status + ': ' + text.substring(0, 200)); });
        }
        return res.json();
      })
      .then(function(data) {
        var msg = '<strong>' + label + ':</strong> RSS ' + formatBytes(data.before_rss) +
          ' &rarr; ' + formatBytes(data.after_rss) +
          ' (' + (data.freed >= 0 ? 'freed ' + formatBytes(data.freed) : 'grew ' + formatBytes(Math.abs(data.freed)) + ' despite our efforts') + ')';
        resultEl.className = 'alert alert-success';
        resultEl.innerHTML = msg;
      })
      .catch(function(err) {
        resultEl.className = 'alert alert-danger';
        resultEl.innerHTML = '<strong>Error:</strong> ' + err;
      });
  }

  document.getElementById('btn-gc').addEventListener('click', function() {
    doAction('/memory/run_gc', 'GC');
  });
  document.getElementById('btn-trim').addEventListener('click', function() {
    doAction('/memory/malloc_trim', 'malloc_trim');
  });
  document.getElementById('btn-refresh').addEventListener('click', function() {
    window.location.reload();
  });
</script>
