<% provide(:title, 'Memory') %>
<h1>Memory Stats <small><%= link_to "JSON", memory_path(format: :json) %></small></h1>

<%
  heap_mb = @stats[:heap_measured_mb]
  gap = @stats[:rss_mb] - heap_mb
  gap_pct = @stats[:rss_mb] > 0 ? (gap / @stats[:rss_mb] * 100).round(0) : 0
  heap_pct = @stats[:rss_mb] > 0 ? (heap_mb / @stats[:rss_mb] * 100).round(0) : 0
  severity = gap > 1000 ? 'danger' : gap > 500 ? 'warning' : 'default'
%>

<div class="panel panel-<%= severity %>">
  <div class="panel-heading"><h4 class="panel-title">Memory Breakdown</h4></div>
  <div class="panel-body" style="padding: 10px 15px;">
    <p style="margin: 0 0 8px;">
      <strong>RSS</strong> <span id="rss-mb"><%= @stats[:rss_mb] %></span> MB
      = <strong>Ruby heap</strong> <span id="heap-mb"><%= heap_mb %></span> MB (<span id="heap-pct"><%= heap_pct %></span>%)
      + <strong>Off-heap</strong> <span id="frag-gap"><%= gap.round(1) %></span> MB (<span id="gap-pct"><%= gap_pct %></span>% — fragmentation, stacks, mmap)
    </p>
    <div class="progress" style="margin: 0; height: 22px;">
      <div class="progress-bar progress-bar-success" id="bar-heap" style="width: <%= heap_pct %>%; line-height: 22px; font-size: 12px;">
        heap <%= heap_mb %> MB
      </div>
      <div class="progress-bar progress-bar-<%= severity %>" id="bar-offheap" style="width: <%= gap_pct %>%; line-height: 22px; font-size: 12px;">
        off-heap <%= gap.round(1) %> MB
      </div>
    </div>
    <% if gap > 1000 %>
      <p class="text-danger" style="margin-top: 10px;">
        <strong><%= gap.round(0) %> MB outside Ruby's heap.</strong>
        This suggests malloc fragmentation or large off-heap allocations (thread stacks, native extensions).
        Try <strong>Force GC</strong> then <strong>malloc_trim</strong> below to see if memory can be reclaimed.
      </p>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-md-4">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">Heap Slots</h4></div>
      <div class="panel-body text-center">
        <p><strong>Live:</strong> <span id="heap-live"><%= number_with_delimiter(@stats[:heap_live_slots]) %></span></p>
        <p><strong>Free:</strong> <span id="heap-free"><%= number_with_delimiter(@stats[:heap_free_slots]) %></span></p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">GC Runs</h4></div>
      <div class="panel-body text-center">
        <h2 id="gc-count"><%= @stats[:gc_count] %></h2>
        <p class="text-muted"><span id="gc-major"><%= @stats[:major_gc_count] %></span> major / <span id="gc-minor"><%= @stats[:minor_gc_count] %></span> minor</p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">Objects</h4></div>
      <div class="panel-body text-center">
        <p><strong>Allocated:</strong> <span id="total-alloc"><%= number_with_delimiter(@stats[:total_allocated_objects]) %></span></p>
        <p><strong>Freed:</strong> <span id="total-freed"><%= number_with_delimiter(@stats[:total_freed_objects]) %></span></p>
        <p><strong>malloc_increase:</strong> <span id="malloc-inc"><%= number_with_delimiter(@stats[:malloc_increase_bytes]) %></span></p>
        <p><strong>oldmalloc_increase:</strong> <span id="oldmalloc-inc"><%= number_with_delimiter(@stats[:oldmalloc_increase_bytes]) %></span></p>
      </div>
    </div>
  </div>
</div>

<div class="well">
  <h4>Actions</h4>
  <button id="btn-gc" class="btn btn-warning">Force GC (3x full)</button>
  <button id="btn-trim" class="btn btn-info" style="margin-left: 10px;">malloc_trim</button>
  <div id="action-result" style="margin-top: 15px;"></div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">Top Classes by Count</h4></div>
      <table class="table table-condensed">
        <thead><tr><th>Class</th><th class="text-right">Count</th></tr></thead>
        <tbody>
          <% @stats[:top_by_count].each do |row| %>
            <tr><td><code><%= row[:class_name] %></code></td><td class="text-right"><%= number_with_delimiter(row[:count]) %></td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="col-md-6">
    <div class="panel panel-default">
      <div class="panel-heading"><h4 class="panel-title">Top Classes by Size</h4></div>
      <table class="table table-condensed">
        <thead><tr><th>Class</th><th class="text-right">Size</th></tr></thead>
        <tbody>
          <% @stats[:top_by_size].each do |row| %>
            <tr><td><code><%= row[:class_name] %></code></td><td class="text-right"><%= (row[:bytes] / 1048576.0).round(1) %> MB</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  function formatBytes(bytes) {
    var abs = Math.abs(bytes);
    var sign = bytes < 0 ? '-' : '';
    if (abs >= 1048576) return sign + (abs / 1048576).toFixed(1) + ' MB';
    if (abs >= 1024) return sign + (abs / 1024).toFixed(1) + ' KB';
    return sign + abs + ' B';
  }

  function numberWithDelimiter(n) {
    return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function updateStats(stats) {
    document.getElementById('rss-mb').textContent = stats.rss_mb;
    document.getElementById('heap-live').textContent = numberWithDelimiter(stats.heap_live_slots);
    document.getElementById('heap-free').textContent = numberWithDelimiter(stats.heap_free_slots);
    document.getElementById('gc-count').textContent = stats.gc_count;
    document.getElementById('gc-major').textContent = stats.major_gc_count;
    document.getElementById('gc-minor').textContent = stats.minor_gc_count;
    document.getElementById('total-alloc').textContent = numberWithDelimiter(stats.total_allocated_objects);
    document.getElementById('total-freed').textContent = numberWithDelimiter(stats.total_freed_objects);
    document.getElementById('malloc-inc').textContent = numberWithDelimiter(stats.malloc_increase_bytes);
    document.getElementById('oldmalloc-inc').textContent = numberWithDelimiter(stats.oldmalloc_increase_bytes);
  }

  function doAction(url, label) {
    var resultEl = document.getElementById('action-result');
    resultEl.className = 'alert alert-info';
    resultEl.innerHTML = '<strong>' + label + ':</strong> Running...';

    fetch(url, {method: 'POST', headers: {'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content}})
      .then(function(res) {
        if (!res.ok) {
          return res.text().then(function(text) { throw new Error('HTTP ' + res.status + ': ' + text.substring(0, 200)); });
        }
        return res.json();
      })
      .then(function(data) {
        var msg = '<strong>' + label + ':</strong> RSS ' + formatBytes(data.before_rss) +
          ' &rarr; ' + formatBytes(data.after_rss) +
          ' (' + (data.freed >= 0 ? 'freed ' + formatBytes(data.freed) : 'grew ' + formatBytes(Math.abs(data.freed)) + ' despite our efforts') + ')';
        resultEl.className = 'alert alert-success';
        resultEl.innerHTML = msg;
        updateStats(data.stats);
      })
      .catch(function(err) {
        resultEl.className = 'alert alert-danger';
        resultEl.innerHTML = '<strong>Error:</strong> ' + err;
      });
  }

  document.getElementById('btn-gc').addEventListener('click', function() {
    doAction('/memory/run_gc', 'GC');
  });

  document.getElementById('btn-trim').addEventListener('click', function() {
    doAction('/memory/malloc_trim', 'malloc_trim');
  });

</script>
