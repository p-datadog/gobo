<% if logged_in? %>
  <div class="row">
    <aside class="col-md-4">
      <section class="user_info">
        <%= render 'shared/user_info' %>
      </section>
      <section class="stats">
        <%= render 'shared/stats' %>
      </section>
      <section class="micropost_form">
        <%= render 'shared/micropost_form' %>
      </section>
      <section style="margin-top: 20px;">
        <h4>Circuit Breaker Test</h4>
        <p style="font-size: 0.9em;">
          Dynamic Instrumentation circuit breaker should disable the probe after one execution
          if execution time in DI (including serialization) exceeds the circuit breaker threshold.
        </p>
        <%= form_with(url: debugger_test_calculate_path, method: :get, local: true, html: { id: 'fibonacci-form-sidebar' }) do |f| %>
          <%= f.label :fibonacci_n, "Fibonacci N (36 ≈ 1 second)" %>
          <%= f.number_field :fibonacci_n, class: 'form-control', value: 36, min: 0, max: 40 %>
          <%= f.submit "Calculate fib(n)", class: "btn btn-success btn-block", style: "margin-top: 10px;" %>
          <%= f.submit "Test circuit breaker", formaction: debugger_test_circuit_breaker_path, class: "btn btn-info btn-block", style: "margin-top: 10px;" %>
        <% end %>
      </section>
      <section style="margin-top: 20px;">
        <h4>DI Demo Features</h4>
        <p style="font-size: 0.9em;">
          View active probes, trigger the JSON encoding error demo (set a probe on
          <code>BinaryDataModel#process</code> to see error handling), and send
          probe status notifications.
        </p>
        <%= link_to "DI Probes", probes_path, class: "btn btn-default btn-block" %>
      </section>
    </aside>
    <div class="col-md-8">
      <h3>Micropost Feed</h3>
      <%= render 'shared/feed' %>
    </div>
  </div>
<% else %>
  <div class="center jumbotron">
    <h1>Welcome to the Sample App</h1>

    <h2>
      This is the home page for the
      <a href="https://www.railstutorial.org/">Ruby on Rails Tutorial</a>
      sample application.
    </h2>

    <h2>
      Use the login form below with "admin@example.com" / "admin".
    </h2>

    <%= link_to "Sign up now!", signup_path, class: "btn btn-lg btn-primary" %>
  </div>

  <div class="row">
    <div class="col-md-6 col-md-offset-3">
      <%= form_with(url: login_path, scope: :session, local: true) do |f| %>

        <%= f.label :email %>
        <%= f.email_field :email, class: 'form-control', value: 'admin@example.com' %>

        <%= f.label :password %>
        <%= f.password_field :password, class: 'form-control' %>

        <%= f.label :remember_me, class: "checkbox inline" do %>
          <%= f.check_box :remember_me %>
          <span>Remember me on this computer</span>
        <% end %>

        <%= f.submit "Log in", class: "btn btn-primary btn-lg btn-block" %>
      <% end %>

      <p style="margin-top: 20px;">New user? <%= link_to "Sign up now!", signup_path %></p>
    </div>
  </div>

  <div class="center" style="margin-top: 40px;">
    <div class="col-md-6 col-md-offset-3">
      <h3>Circuit Breaker Test</h3>
      <p>
        Dynamic Instrumentation circuit breaker should disable the probe after one execution
        if execution time in DI (including serialization) exceeds the circuit breaker threshold.
      </p>
      <%= form_with(url: debugger_test_calculate_path, method: :get, local: true, html: { id: 'fibonacci-form-main' }) do |f| %>
        <%= f.label :fibonacci_n, "Fibonacci N (36 ≈ 1 second)" %>
        <%= f.number_field :fibonacci_n, class: 'form-control', value: 36, min: 0, max: 40 %>
        <%= f.submit "Calculate fib(n)", class: "btn btn-success btn-lg btn-block", style: "margin-top: 10px;" %>
        <%= f.submit "Test circuit breaker", formaction: debugger_test_circuit_breaker_path, class: "btn btn-info btn-lg btn-block", style: "margin-top: 10px;" %>
      <% end %>
    </div>
  </div>

  <div class="center" style="margin-top: 30px;">
    <div class="col-md-8 col-md-offset-2">
      <h3>Micropost Feed</h3>
      <%= render 'shared/feed' %>
    </div>
  </div>

  <div class="center" style="margin-top: 40px;">
    <div class="col-md-8 col-md-offset-2">
      <h3>DI Demo Features</h3>
      <p>
        This app demonstrates Datadog Dynamic Instrumentation features. Use the links below
        to explore available demos.
      </p>
      <ul class="list-unstyled" style="text-align: left; display: inline-block;">
        <li style="margin-bottom: 8px;">
          <%= link_to "DI Probes", probes_path %> &mdash;
          View active probes and their status. Trigger the JSON encoding error demo
          (set a probe on <code>BinaryDataModel#process</code> to see snapshot error handling).
        </li>
        <li style="margin-bottom: 8px;">
          <strong>Circuit Breaker Test</strong> (form above) &mdash;
          Demonstrates the DI circuit breaker disabling a probe when serialization exceeds
          the time threshold.
        </li>
        <li>
          <strong>Fibonacci Calculator</strong> (form above) &mdash;
          Plain function execution with a DI probe on <code>ExpensiveModel.fibonacci</code>.
        </li>
      </ul>
    </div>
  </div>

  <div class="center" style="margin-top: 50px; clear: both;">
    <%= link_to image_tag("rails.svg", alt: "Rails logo", width: "200"),
                          "https://rubyonrails.org/" %>
  </div>
<% end %>
