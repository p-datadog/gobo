<% provide(:title, 'Symbol Database Demo') %>
<h1>Symbol Database Demo <small><%= link_to "JSON", symdb_path(format: :json) %></small></h1>

<p class="lead">
  Sample classes and modules for exercising symbol database extraction and upload.
  After upload, these should appear in the Datadog UI's symbol database for this service.
</p>

<% if @service %>
  <% encoded_service = ERB::Util.url_encode(@service) %>
  <% symdb_base = "https://dd.datad0g.com/api/unstable/symdb-api" %>
  <div class="panel panel-info">
    <div class="panel-heading"><h4 class="panel-title">Staging API queries</h4></div>
    <div class="panel-body">
      <ul style="margin-bottom: 0;">
        <li>
          <%= link_to "Service metadata",
            "#{symdb_base}/services/metadata?service=#{encoded_service}&allow_partial=true",
            target: "_blank" %>
          &mdash; versions registered for this service
        </li>
        <li>
          <%= link_to "Uploaded files",
            "#{symdb_base}/files?service=#{encoded_service}&allow_partial=true",
            target: "_blank" %>
          &mdash; list of source files in the upload
        </li>
        <li>
          <%= link_to "Search scopes",
            "#{symdb_base}/scopes/search?service=#{encoded_service}&query=SymdbSamples&allow_partial=true",
            target: "_blank" %>
          &mdash; scopes whose name starts with <code>SymdbSamples</code>
        </li>
        <li>
          <%= link_to "File scopes",
            "#{symdb_base}/scopes/file?service=#{encoded_service}&source_file=#{ERB::Util.url_encode('app/models/symdb_samples/basic_class.rb')}&allow_partial=true",
            target: "_blank" %>
          &mdash; scopes inside <code>basic_class.rb</code>
        </li>
      </ul>
    </div>
  </div>
<% end %>

<%= render 'shared/datadog_status',
      service: @service,
      env: @env,
      version: @version,
      git_repository_url: @git_repository_url,
      git_commit_sha: @git_commit_sha,
      agent_address: @agent_address %>

<div class="panel panel-info">
  <div class="panel-heading"><h4 class="panel-title">Symbol Database</h4></div>
  <div class="panel-body">
    <p>
      <strong>Configuration:</strong>
      <% if @symdb_enabled %>
        <span class="label label-success">Enabled</span>
      <% else %>
        <span class="label label-danger">Disabled</span>
      <% end %>
    </p>
    <p>
      <strong>Component:</strong>
      <% case @component_status %>
      <% when :active %>
        <span class="label label-success">Active</span>
      <% when :not_created %>
        <span class="label label-warning">Not created</span>
        <span class="text-muted">&mdash; preconditions not met (check enabled, Ruby version, remote config)</span>
      <% when :shutdown %>
        <span class="label label-danger">Shutdown</span>
      <% when :no_datadog %>
        <span class="label label-default">N/A</span>
        <span class="text-muted">&mdash; Datadog::SymbolDatabase not loaded</span>
      <% when :error %>
        <span class="label label-danger">Error</span>
        <span class="text-muted">&mdash; could not read component status (check logs)</span>
      <% end %>
    </p>
    <p>
      <strong>RC requested upload:</strong>
      <% if @upload_info.nil? %>
        <span class="text-muted">Unknown (older tracer without diagnostic accessors)</span>
      <% elsif @upload_info[:rc_requested_at] %>
        <% delta = @upload_info[:rc_requested_at] - Process.clock_gettime(Process::CLOCK_MONOTONIC, :float_second) %>
        <span class="label label-success">Yes</span>
        <% if delta > 0 %>
          <span class="text-muted">&mdash; firing in <%= delta.round(1) %>s (debounce window)</span>
        <% else %>
          <span class="text-muted">&mdash; triggered <%= distance_of_time_in_words(-delta) %> ago</span>
        <% end %>
      <% else %>
        <span class="label label-default">No</span>
      <% end %>
    </p>
    <p>
      <strong>Last upload:</strong>
      <% if @upload_info.nil? %>
        <span class="text-muted">Unknown (older tracer without diagnostic accessors)</span>
      <% elsif @upload_info[:upload_in_progress] %>
        <span class="label label-info">In progress</span>
      <% elsif @upload_info[:last_upload_time] %>
        <% ago = Time.now - @upload_info[:last_upload_time] %>
        <code><%= @upload_info[:last_upload_time].strftime('%Y-%m-%d %H:%M:%S') %></code>
        <span class="text-muted">
          (<%= distance_of_time_in_words(ago) %> ago<% if @upload_info[:last_upload_scope_count] %>, <%= pluralize(@upload_info[:last_upload_scope_count], 'scope') %><% end %>)
        </span>
      <% else %>
        <span class="text-muted">Never</span>
      <% end %>
    </p>
  </div>
</div>

<h3>Expected Classes in Symbol Database</h3>

<p>
  Each file below contains sample classes/modules designed to exercise specific symbol database features.
  After a successful upload, search for these names in the
  <a href="https://app.datadoghq.com/debugging" target="_blank">Datadog DI UI</a>
  autocomplete.
</p>

<% @sample_classes.each do |group| %>
  <div class="panel panel-default">
    <div class="panel-heading">
      <h4 class="panel-title"><code><%= group[:file] %></code></h4>
    </div>
    <table class="table table-striped">
      <thead>
        <tr>
          <th style="width: 15%">Scope</th>
          <th style="width: 35%">Name</th>
          <th>What it exercises</th>
        </tr>
      </thead>
      <tbody>
        <% group[:entries].each do |entry| %>
          <tr>
            <td><span class="label label-<%= entry[:type] == :CLASS ? 'primary' : 'info' %>"><%= entry[:type] %></span></td>
            <td><code><%= entry[:name] %></code></td>
            <td><%= entry[:description] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="panel panel-warning">
  <div class="panel-heading"><h4 class="panel-title">Scope Hierarchy</h4></div>
  <div class="panel-body">
    <p>Ruby uploads use <strong>FILE</strong> as the root scope (one per source file), with CLASS and MODULE scopes nested inside:</p>
    <pre>FILE (/app/app/models/symdb_samples/basic_class.rb)
  file_hash in language_specifics
  CLASS (SymdbSamples::BasicClass)
    STATIC_FIELD: GREETING, @@instance_count
    METHOD: greet, describe, ...
      ARG symbols for each parameter</pre>
    <p>
      Namespace modules are created by FQN splitting. For example, <code>SymdbSamples::Namespaces::Outer::Inner</code> produces:
    </p>
    <pre>FILE (namespaces.rb)
  MODULE (SymdbSamples::Namespaces::Outer)
    CLASS (SymdbSamples::Namespaces::Outer::Inner)
      METHOD scopes...</pre>
  </div>
</div>
