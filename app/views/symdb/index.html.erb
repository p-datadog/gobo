<% provide(:title, 'Symbol Database Demo') %>
<h1>Symbol Database Demo <small><%= link_to "JSON", symdb_path(format: :json) %></small></h1>

<p class="lead">
  Sample classes and modules for exercising symbol database extraction and upload.
  After upload, these should appear in the Datadog UI's symbol database for this service.
</p>

<div class="panel panel-info">
  <div class="panel-heading"><h4 class="panel-title">Status</h4></div>
  <div class="panel-body">
    <div class="row">
      <div class="col-md-3">
        <strong>DD_SERVICE:</strong>
        <% if @service %>
          <code><%= @service %></code>
        <% else %>
          <span class="text-muted">Not configured</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <strong>DD_ENV:</strong>
        <% if @env %>
          <code><%= @env %></code>
        <% else %>
          <span class="text-muted">Not configured</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <strong>Symbol Database:</strong>
        <% if @symdb_enabled %>
          <span class="label label-success">Enabled</span>
        <% else %>
          <span class="label label-danger">Disabled</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <strong>Upload:</strong>
        <% if @upload_enabled %>
          <span class="label label-success">Enabled</span>
        <% else %>
          <span class="label label-danger">Disabled</span>
        <% end %>
      </div>
    </div>
    <div class="row" style="margin-top: 10px;">
      <div class="col-md-12">
        <strong>Component:</strong>
        <% case @component_status %>
        <% when :active %>
          <span class="label label-success">Active</span>
          <span class="text-muted">&mdash; component created, upload can be triggered via remote config</span>
        <% when :not_created %>
          <span class="label label-warning">Not created</span>
          <span class="text-muted">&mdash; preconditions not met (check enabled, Ruby version, remote config)</span>
        <% when :shutdown %>
          <span class="label label-danger">Shutdown</span>
        <% when :no_datadog %>
          <span class="label label-default">N/A</span>
          <span class="text-muted">&mdash; Datadog::SymbolDatabase not loaded</span>
        <% when :error %>
          <span class="label label-danger">Error</span>
          <span class="text-muted">&mdash; could not read component status (check logs)</span>
        <% end %>
      </div>
    </div>
    <% if @component_status != :active %>
      <div class="row" style="margin-top: 10px;">
        <div class="col-md-12">
          <p class="text-muted" style="margin-bottom: 0;">
            To verify upload is working, run with <code>DD_TRACE_DEBUG=1</code> and look for
            <code>symdb: uploaded N scopes successfully</code> in the logs.
          </p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<h3>Expected Classes in Symbol Database</h3>

<p>
  Each file below contains sample classes/modules designed to exercise specific symbol database features.
  After a successful upload, search for these names in the
  <a href="https://app.datadoghq.com/debugging" target="_blank">Datadog DI UI</a>
  autocomplete.
</p>

<% @sample_classes.each do |group| %>
  <div class="panel panel-default">
    <div class="panel-heading">
      <h4 class="panel-title"><code><%= group[:file] %></code></h4>
    </div>
    <table class="table table-striped">
      <thead>
        <tr>
          <th style="width: 15%">Scope</th>
          <th style="width: 35%">Name</th>
          <th>What it exercises</th>
        </tr>
      </thead>
      <tbody>
        <% group[:entries].each do |entry| %>
          <tr>
            <td><span class="label label-<%= entry[:type] == :CLASS ? 'primary' : 'info' %>"><%= entry[:type] %></span></td>
            <td><code><%= entry[:name] %></code></td>
            <td><%= entry[:description] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="panel panel-warning">
  <div class="panel-heading"><h4 class="panel-title">Scope Hierarchy</h4></div>
  <div class="panel-body">
    <p>Ruby uploads use <strong>FILE</strong> as the root scope (one per source file), with CLASS and MODULE scopes nested inside:</p>
    <pre>FILE (/app/app/models/symdb_samples/basic_class.rb)
  file_hash in language_specifics
  CLASS (SymdbSamples::BasicClass)
    STATIC_FIELD: GREETING, @@instance_count
    METHOD: greet, describe, ...
      ARG symbols for each parameter</pre>
    <p>
      Namespace modules are created by FQN splitting. For example, <code>SymdbSamples::Namespaces::Outer::Inner</code> produces:
    </p>
    <pre>FILE (namespaces.rb)
  MODULE (SymdbSamples::Namespaces::Outer)
    CLASS (SymdbSamples::Namespaces::Outer::Inner)
      METHOD scopes...</pre>
  </div>
</div>
