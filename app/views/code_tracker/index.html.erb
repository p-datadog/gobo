<% provide(:title, 'DI Code Tracker') %>
<h1>DI Code Tracker Registry</h1>

<p class="lead">
  Files known to DI's CodeTracker. Line probes can only target files in this registry.
  The backfill (PR #5496) populates it with files loaded before DI started.
</p>

<div class="panel panel-info">
  <div class="panel-heading"><h4 class="panel-title">Status</h4></div>
  <div class="panel-body">
    <p><strong>Code tracking active:</strong>
      <% if @tracking_active %>
        <span class="label label-success">Yes</span>
      <% else %>
        <span class="label label-danger">No</span>
      <% end %>
    </p>
    <p><strong>Total files:</strong> <%= @entries.size %></p>
    <p>
      <span class="label label-primary">App: <%= @counts[:app] %></span>
      <span class="label label-warning">Gem: <%= @counts[:gem] %></span>
      <span class="label label-default">Stdlib: <%= @counts[:stdlib] %></span>
      <span class="label label-info">Other: <%= @counts[:other] %></span>
    </p>
    <% if @error %>
      <div class="alert alert-danger"><%= @error %></div>
    <% end %>
  </div>
</div>

<% if @audit %>
<div class="panel panel-warning">
  <div class="panel-heading"><h4 class="panel-title">Audit: Registry vs $LOADED_FEATURES</h4></div>
  <div class="panel-body">
    <p><strong>Loaded .rb files:</strong> <%= @audit[:loaded_rb] %></p>
    <p><strong>C extensions:</strong> <%= @audit[:c_extensions] %> (not trackable)</p>
    <p><strong>Tracked in registry:</strong> <%= @audit[:tracked] %></p>
    <p><strong>Missing from registry:</strong> <%= @audit[:missing] %>
      <% if @audit[:missing] > 0 %>
        (line probes won't work on these files)
      <% end %>
    </p>
    <% if @audit[:missing_app]&.any? %>
      <p><strong>Missing app files:</strong></p>
      <ul>
        <% @audit[:missing_app].each do |path| %>
          <li><code><%= path %></code></li>
        <% end %>
      </ul>
    <% end %>
    <% if @audit[:missing_by_category]&.any? %>
      <% coverage = @audit[:method_iseq_coverage] %>
      <table class="table table-condensed table-striped" style="margin-top: 10px;">
        <thead>
          <tr>
            <th>Category</th>
            <th>Missing</th>
            <% if coverage %>
              <th>Have method iseqs</th>
              <th>No iseqs at all</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% [:app, :gem, :stdlib, :other].each do |cat| %>
            <% files = @audit[:missing_by_category][cat] %>
            <% next unless files&.any? %>
            <tr>
              <td><span class="label label-<%= {app: 'primary', gem: 'warning', stdlib: 'default', other: 'info'}[cat] %>"><%= cat %></span></td>
              <td><%= files.size %></td>
              <% if coverage %>
                <% cat_cov = coverage[:by_category][cat] %>
                <td><%= cat_cov[:with_method_iseqs] %></td>
                <td><%= cat_cov[:total] - cat_cov[:with_method_iseqs] %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
    <% if @audit[:method_iseq_coverage] %>
      <% coverage = @audit[:method_iseq_coverage] %>
      <p style="margin-top: 10px;">
        <strong>Per-method iseq summary:</strong>
        <%= coverage[:missing_with_method_iseqs] %> of <%= @audit[:missing] %> missing files
        have surviving method iseqs (<%= coverage[:total_method_iseqs] %> iseqs total).
        <%= coverage[:missing_without_any_iseqs] %> files have no iseqs at all (GC'd completely).
      </p>
      <p class="text-muted">
        Files with method iseqs could be supported by per-method iseq line probe targeting (follow-up to PR #5496).
      </p>
    <% end %>
  </div>
</div>
<% end %>

<div class="form-group">
  <input type="text" id="path-filter" class="form-control" placeholder="Filter by path (e.g. activerecord, puma, app/models)">
</div>

<table class="table table-condensed table-striped" id="registry-table">
  <thead>
    <tr>
      <th>Category</th>
      <th>Path</th>
      <th>Type</th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |entry| %>
      <tr data-path="<%= entry[:path].downcase %>">
        <td>
          <% case entry[:category] %>
          <% when :app %>
            <span class="label label-primary">app</span>
          <% when :gem %>
            <span class="label label-warning">gem</span>
          <% when :stdlib %>
            <span class="label label-default">stdlib</span>
          <% else %>
            <span class="label label-info">other</span>
          <% end %>
        </td>
        <td><code style="font-size: 0.85em;"><%= entry[:path] %></code></td>
        <td>
          <% if entry[:iseq_type] %>
            <% case entry[:iseq_type] %>
            <% when :top, :main %>
              <span class="label label-success"><%= entry[:iseq_type] %></span>
            <% else %>
              <span class="label label-warning"><%= entry[:iseq_type] %> (line <%= entry[:first_lineno] %>)</span>
            <% end %>
          <% elsif entry[:first_lineno] == 0 %>
            <span class="label label-success">whole-file</span>
          <% else %>
            <span class="label label-warning">line <%= entry[:first_lineno] %></span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p id="filter-count" class="text-muted"></p>

<script>
  var filterInput = document.getElementById('path-filter');
  var rows = document.querySelectorAll('#registry-table tbody tr');
  var countEl = document.getElementById('filter-count');

  filterInput.addEventListener('input', function() {
    var query = this.value.toLowerCase();
    var shown = 0;
    rows.forEach(function(row) {
      var match = !query || row.getAttribute('data-path').indexOf(query) !== -1;
      row.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    countEl.textContent = query ? 'Showing ' + shown + ' of ' + rows.length + ' files' : '';
  });
</script>
