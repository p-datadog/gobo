<% provide(:title, 'DI Code Tracker') %>
<h1>DI Code Tracker Registry <small><%= link_to "JSON", code_tracker_path(format: :json) %></small></h1>

<p class="lead">
  Files known to DI's CodeTracker. Line probes can only target files in this registry.
</p>

<div class="panel panel-info">
  <div class="panel-heading"><h4 class="panel-title">Status</h4></div>
  <div class="panel-body">
    <p><strong>Code tracking active:</strong>
      <% if @tracking_active %>
        <span class="label label-success">Yes</span>
      <% else %>
        <span class="label label-danger">No</span>
      <% end %>
    </p>
    <% if @error %>
      <div class="alert alert-danger"><%= @error %></div>
    <% end %>
  </div>
</div>

<% if @audit %>
<div class="panel panel-warning">
  <div class="panel-heading"><h4 class="panel-title">Line Probe Coverage</h4></div>
  <div class="panel-body">
    <p><strong>Loaded .rb files:</strong> <%= @audit[:loaded_rb] %></p>
    <p><strong>C extensions:</strong> <%= @audit[:c_extensions] %> (not trackable)</p>
    <p>
      <span class="label label-success">Fully covered: <%= @audit[:fully_covered] %></span>
      &mdash; whole-file iseq, line probes work on any line
    </p>
    <p>
      <span class="label label-warning">Partially covered: <%= @audit[:partially_covered] %></span>
      &mdash; per-method iseqs only (<%= @audit[:total_method_iseqs] %> iseqs), line probes work within methods
    </p>
    <p>
      <span class="label label-danger">Not covered: <%= @audit[:not_covered] %></span>
      &mdash; no surviving iseqs, line probes cannot target these files
    </p>
    <% if @audit[:not_covered_by_category]&.any? || @audit[:partially_by_category]&.any? %>
      <table class="table table-condensed table-striped" style="margin-top: 10px;">
        <thead>
          <tr><th>Category</th><th>Partially covered</th><th>Not covered</th></tr>
        </thead>
        <tbody>
          <% [:app, :gem, :stdlib, :other].each do |cat| %>
            <% partial = @audit[:partially_by_category][cat]&.size || 0 %>
            <% none = @audit[:not_covered_by_category][cat]&.size || 0 %>
            <% next if partial == 0 && none == 0 %>
            <tr>
              <td><span class="label label-<%= {app: 'primary', gem: 'warning', stdlib: 'default', other: 'info'}[cat] %>"><%= cat %></span></td>
              <td><%= partial %></td>
              <td><%= none %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
    <p style="margin-top: 10px;">
      <%= link_to "View full list (all #{@all_entries.size} files)", code_tracker_full_path %>
    </p>
  </div>
</div>
<% end %>

<h3>App &amp; Stdlib Files (<%= @entries.size %>)</h3>

<div class="form-group">
  <input type="text" id="path-filter" class="form-control" placeholder="Filter by path...">
</div>

<%= render partial: 'file_table', locals: { entries: @entries } %>

<p id="filter-count" class="text-muted"></p>

<script>
  var filterInput = document.getElementById('path-filter');
  var rows = document.querySelectorAll('#registry-table tbody tr');
  var countEl = document.getElementById('filter-count');

  filterInput.addEventListener('input', function() {
    var query = this.value.toLowerCase();
    var shown = 0;
    rows.forEach(function(row) {
      var match = !query || row.getAttribute('data-path').indexOf(query) !== -1;
      row.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    countEl.textContent = query ? 'Showing ' + shown + ' of ' + rows.length + ' files' : '';
  });
</script>
