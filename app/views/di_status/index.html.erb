<% provide(:title, 'DI Status') %>
<h1>DI Status <small><%= link_to "JSON", di_status_path(format: :json) %></small></h1>

<p>
  <a href="https://<%= AgentEnvironments.fetch('dogfood')[:ui_host] %>/debugging/sessions" target="_blank">
    View Debugging Sessions in Datadog &rarr;
  </a>
</p>

<%= render 'shared/datadog_status',
      service: @service,
      env: @env,
      version: @version,
      git_repository_url: @git_repository_url,
      git_commit_sha: @git_commit_sha,
      agent_address: @agent_address,
      agent_environment_label: @agent_environment_label,
      agent_operational: @agent_operational %>

<div class="panel panel-info">
  <div class="panel-heading"><h4 class="panel-title">Dynamic Instrumentation</h4></div>
  <div class="panel-body">
    <strong>DI Enabled:</strong>
    <% case @di_enabled %>
    <% when :enabled_explicitly %>
      <span class="text-success"><strong>✓ Yes — explicitly enabled</strong></span>
      <span class="text-muted">(DD_DYNAMIC_INSTRUMENTATION_ENABLED=true)</span>
    <% when :enabled_implicitly %>
      <span class="text-success"><strong>✓ Yes — enabled remotely</strong></span>
      <span class="text-muted">(turned on by Remote Configuration)</span>
    <% when :disabled_explicitly %>
      <span class="text-danger"><strong>✗ No — explicitly disabled</strong></span>
      <span class="text-muted">(DD_DYNAMIC_INSTRUMENTATION_ENABLED=false; blocks remote enablement)</span>
    <% when :explicitly_enabled_rc_disabled %>
      <span class="text-danger"><strong>✗ No — disabled by Remote Configuration</strong></span>
      <span class="text-muted">(DD_DYNAMIC_INSTRUMENTATION_ENABLED=true, but RC turned DI off)</span>
    <% when :can_enable_remotely %>
      <span class="text-warning"><strong>✗ No — can be enabled remotely</strong></span>
    <% when :error %>
      <span class="text-danger"><strong>✗ Unknown — status check failed</strong></span>
      <span class="text-muted">(an error occurred while checking DI status; see below)</span>
    <% else %>
      <span class="text-muted"><strong>✗ No — unavailable</strong></span>
      <% if @di_unavailable_reason.present? %>
        <span class="text-muted">(<%= @di_unavailable_reason %>)</span>
      <% else %>
        <span class="text-muted">(dynamic instrumentation is not available in this environment)</span>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      REDAPL <code>service_config</code> environments
      <% if @redapl_target %>
        <small><%= link_to "Query REDAPL service_config for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <% if @redapl %>
      <dl class="dl-horizontal">
        <dt>Lookback:</dt><dd><%= @redapl[:window_minutes] %> minute(s)</dd>
        <dt>Query:</dt><dd><pre><%= @redapl[:query] %></pre></dd>
      </dl>

      <% if @redapl[:error] %>
        <div class="alert alert-danger">
          <strong>REDAPL query failed:</strong>
          <pre><%= @redapl[:error] %></pre>
        </div>
      <% elsif @redapl[:rows].empty? %>
        <div class="alert alert-warning">
          No <code>service_config</code> rows for
          <% if @service %><code><%= @service %></code><% else %>any service<% end %>
          in the last <%= @redapl[:window_minutes] %> minute(s).
        </div>
      <% else %>
        <table class="table table-striped table-condensed">
          <thead>
            <tr><th>service_name</th><th>language_name</th><th>env</th></tr>
          </thead>
          <tbody>
            <% @redapl[:rows].each do |row| %>
              <tr>
                <td><code><%= row[:service_name] %></code></td>
                <td><%= row[:language_name] %></td>
                <td><code><%= row[:env] %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Remote enablement (DI enable state)
      <% if @redapl_target %>
        <small><%= link_to "Query remote enablement for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <p class="text-muted">
      The DI enable state the backend stores for this service and env, in the
      <code>apm_tracing</code> remote-config product. This decides whether
      Remote Configuration turns DI on when the tracer reports
      <code>can_enable_remotely</code>.
    </p>

    <% if @remote_enablement %>
      <dl class="dl-horizontal">
        <dt>Endpoint:</dt>
        <dd><pre><%= link_to @remote_enablement[:path], "https://#{@remote_enablement[:host]}#{@remote_enablement[:path]}", target: "_blank", rel: "noopener" %></pre></dd>
      </dl>

      <% if @remote_enablement[:error] %>
        <div class="alert alert-danger">
          <strong>remote enablement query failed:</strong>
          <pre><%= @remote_enablement[:error] %></pre>
        </div>
      <% elsif @remote_enablement[:configs].empty? %>
        <div class="alert alert-warning">
          No <code>apm_tracing</code> debugger config for
          <code><%= @remote_enablement[:service] %></code> in
          <code><%= @remote_enablement[:env] %></code>. DI has never been enabled
          remotely for this service and env.
        </div>
      <% else %>
        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>dynamic_instrumentation_enabled</th><th>config_exists</th>
              <th>client_library_version</th><th>language</th><th>last modified</th>
            </tr>
          </thead>
          <tbody>
            <% @remote_enablement[:configs].each do |c| %>
              <tr>
                <td><%= di_enable_state_label(c[:dynamic_instrumentation_enabled]) %></td>
                <td><%= c[:config_exists] %></td>
                <td><%= c[:client_library_version] %></td>
                <td><%= c[:language] %></td>
                <td>
                  <% if c[:modified_time].to_i > 0 %>
                    <code><%= Time.at(c[:modified_time].to_i).utc.iso8601 %></code>
                  <% else %>
                    (none)
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Debugger heartbeats (instance coverage)
      <% if @redapl_target %>
        <small><%= link_to "Query debugger heartbeats for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <p class="text-muted">
      Source of the DI service page's <code>N instances active</code> panel:
      <code>/api/ui/debugger/services</code> +
      <code>/api/ui/debugger/heartbeats/details/{service}</code> (debugger
      edge-api). One row per tracer runtime (e.g. per Puma worker).
    </p>

    <% if @heartbeats %>
      <dl class="dl-horizontal">
        <dt>Endpoint:</dt>
        <dd><pre><%= link_to "/api/ui/debugger/heartbeats/details/#{@heartbeats[:service]}", "https://#{@heartbeats[:host]}/api/ui/debugger/heartbeats/details/#{@heartbeats[:service]}", target: "_blank", rel: "noopener" %></pre></dd>
        <dt>Service last seen:</dt>
        <dd>
          <code><%= @heartbeats[:last_seen] || '(none)' %></code>
          <% if (ago = time_ago_since(@heartbeats[:last_seen])) %>
            <span class="text-muted">(<%= ago %>)</span>
          <% end %>
        </dd>
      </dl>

      <% if @heartbeats[:error] %>
        <div class="alert alert-danger">
          <strong>debugger heartbeats query failed:</strong>
          <pre><%= @heartbeats[:error] %></pre>
        </div>
      <% elsif @heartbeats[:instances].empty? %>
        <div class="alert alert-warning">
          No debugger heartbeats for <code><%= @heartbeats[:service] %></code>
          in <code><%= @heartbeats[:env] %></code>.
        </div>
      <% else %>
        <h4><%= pluralize(@heartbeats[:instances].size, 'instance') %></h4>
        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>runtime_id</th><th>hostname</th><th>env</th><th>version</th>
              <th>tracer</th><th>agent</th><th>language</th><th>last_seen</th>
            </tr>
          </thead>
          <tbody>
            <% @heartbeats[:instances].each do |i| %>
              <% local = di_local_runtime?(@local_runtime_ids, i[:runtime_id]) %>
              <tr class="<%= 'success' if local %>">
                <td>
                  <code><%= i[:runtime_id] %></code>
                  <% if local %><span class="label label-success">this process</span><% end %>
                </td>
                <td><%= i[:hostname] || 'NOT DETECTED' %></td>
                <td><code><%= i[:service_env] %></code></td>
                <td><%= i[:service_version] %></td>
                <td><%= i[:tracer_version] %></td>
                <td><%= i[:agent_id] %></td>
                <td><%= i[:language] %></td>
                <td><%= i[:last_seen] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Live service instances (APM telemetry)
      <% if @redapl_target %>
        <small><%= link_to "Query live-service-instances for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <p class="text-muted">
      APM-domain <code>live-service-instances</code> service (instrumentation
      telemetry + REDAPL join). Separate from the debugger heartbeats above: a
      service can heartbeat for DI yet be absent here when its APM
      instrumentation telemetry is not landing.
    </p>

    <% if @instances %>
      <dl class="dl-horizontal">
        <dt>Endpoint:</dt>
        <dd><pre><%= link_to @instances[:endpoint], "https://#{@instances[:host]}#{@instances[:endpoint]}", target: "_blank", rel: "noopener" %></pre></dd>
      </dl>

      <% if @instances[:error] %>
        <div class="alert alert-danger">
          <strong>live-service-instances query failed:</strong>
          <pre><%= @instances[:error] %></pre>
        </div>
      <% elsif @instances[:active].empty? %>
        <div class="alert alert-warning">
          No active instances for <code><%= @instances[:service] %></code>
          in <code><%= @instances[:env] %></code>.
          <% unless @instances[:inactive].empty? %>
            (<%= pluralize(@instances[:inactive].size, 'inactive instance') %> present.)
          <% end %>
          <% if @instances[:environment] == 'staging' %>
            <strong>Expected to be empty in staging (move to ddstaging)</strong>
          <% end %>
        </div>
      <% end %>

      <% [['Active', @instances[:active]], ['Inactive', @instances[:inactive]]].each do |label, rows| %>
        <% next if rows.empty? %>
        <h4><%= label %> (<%= rows.size %>)</h4>
        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>runtime_id</th><th>hostname</th><th>env</th><th>version</th>
              <th>tracer</th><th>agent</th><th>di_enabled</th>
              <th>rc_products</th><th>language</th>
            </tr>
          </thead>
          <tbody>
            <% rows.each do |i| %>
              <% local = di_local_runtime?(@local_runtime_ids, i[:runtime_id]) %>
              <tr class="<%= 'success' if local %>">
                <td>
                  <code><%= i[:runtime_id] %></code>
                  <% if local %><span class="label label-success">this process</span><% end %>
                </td>
                <td><%= i[:hostname] %></td>
                <td><code><%= i[:service_env] %></code></td>
                <td><%= i[:service_version] %></td>
                <td><%= i[:client_library_version] %></td>
                <td><%= i[:agent_version] %></td>
                <td><%= i[:di_enabled] %></td>
                <td><%= Array(i[:remote_config_products]).join(', ') %></td>
                <td><%= i[:language_name] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Debugger sessions (for this service)
      <% if @redapl_target %>
        <small><%= link_to "Query debugger sessions for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <p class="text-muted">
      Live Debugger sessions whose <code>serviceNames</code> include
      <code><%= @service %></code>, from
      <code>/api/ui/debugger/live-debugger/sessions</code>.
    </p>

    <% if @debugger_sessions %>
      <dl class="dl-horizontal">
        <dt>Endpoint:</dt>
        <dd><pre><%= link_to "/api/ui/debugger/live-debugger/sessions", "https://#{@debugger_sessions[:host]}/api/ui/debugger/live-debugger/sessions", target: "_blank", rel: "noopener" %></pre></dd>
      </dl>

      <% if @debugger_sessions[:error] %>
        <div class="alert alert-danger">
          <strong>debugger sessions query failed:</strong>
          <pre><%= @debugger_sessions[:error] %></pre>
        </div>
      <% elsif @debugger_sessions[:sessions].empty? %>
        <div class="alert alert-warning">
          No debugger sessions target <code><%= @debugger_sessions[:service] %></code>.
        </div>
      <% else %>
        <h4><%= pluralize(@debugger_sessions[:sessions].size, 'session') %></h4>
        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>id</th><th>name</th><th>probes</th><th>disabled</th>
              <th>expires</th><th>created by</th><th>services</th>
            </tr>
          </thead>
          <tbody>
            <% @debugger_sessions[:sessions].each do |s| %>
              <tr>
                <td><code><%= s[:id] %></code></td>
                <td><%= s[:name] %></td>
                <td><%= s[:num_probes] %></td>
                <td><%= s[:disabled] %></td>
                <td>
                  <% if s[:expires].to_i > 0 %>
                    <code><%= Time.at(s[:expires].to_i / 1000).utc.iso8601 %></code>
                  <% else %>
                    never
                  <% end %>
                </td>
                <td><%= s[:created_by] %></td>
                <td><%= Array(s[:service_names]).join(', ') %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Backend probes and statuses (for this service)
      <% if @redapl_target %>
        <small><%= link_to "Query backend probes for #{@redapl_target} &rarr;".html_safe, di_status_path(redapl: @redapl_target) %></small>
      <% end %>
    </h4>
  </div>
  <div class="panel-body">
    <p class="text-muted">
      Probes the backend holds for <code><%= @service %></code> and their
      aggregate status, from <code>/api/ui/debugger/probe-statuses</code>. The
      backend's view across all runtimes, distinct from the in-process probe
      list at the top of this page.
    </p>

    <% if @backend_probes %>
      <dl class="dl-horizontal">
        <dt>Endpoint:</dt>
        <dd><pre><%= link_to "/api/ui/debugger/probe-statuses", "https://#{@backend_probes[:host]}/api/ui/debugger/probe-statuses", target: "_blank", rel: "noopener" %></pre></dd>
      </dl>

      <% if @backend_probes[:error] %>
        <div class="alert alert-danger">
          <strong>probe statuses query failed:</strong>
          <pre><%= @backend_probes[:error] %></pre>
        </div>
      <% elsif @backend_probes[:probes].empty? %>
        <div class="alert alert-warning">
          No backend probes for <code><%= @backend_probes[:service] %></code>.
        </div>
      <% else %>
        <h4><%= pluralize(@backend_probes[:probes].size, 'probe') %></h4>
        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>id</th><th>status</th><th>summary</th>
              <th>last captured</th><th>updated</th><th>diagnostics</th>
            </tr>
          </thead>
          <tbody>
            <% @backend_probes[:probes].each do |p| %>
              <tr>
                <td><code><%= p[:id] %></code></td>
                <td><%= di_probe_status_label(p[:status]) %></td>
                <td><%= Array(p[:summary]).join(' ') %></td>
                <td><%= p[:last_captured] || '(none)' %></td>
                <td><%= p[:probe_updated_at] %></td>
                <td>
                  <% Array(p[:diagnostics]).each do |d| %>
                    <div><code><%= d[:runtime_id] %></code>: <%= d[:status] %><% if d[:exception] %> (<%= d[:exception][:type] %>)<% end %></div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
</div>

<% if @redapl_connection %>
<div class="panel panel-info">
  <div class="panel-heading">
    <h4 class="panel-title">
      Datadog API session
      <small><%= link_to "JSON", di_status_path(format: :json, redapl: @redapl_env) %></small>
    </h4>
  </div>
  <div class="panel-body">
    <dl class="dl-horizontal">
      <dt>Environment:</dt><dd><code><%= @redapl_connection[:environment] %></code></dd>
      <dt>Host:</dt><dd><code><%= @redapl_connection[:host] %></code></dd>
      <dt>Cookies:</dt><dd><code><%= @redapl_connection[:cookie_path] %></code></dd>
    </dl>
  </div>
</div>
<% end %>

<% if @error %>
  <div class="alert alert-danger">
    <h4><strong>Error Fetching Probes</strong></h4>
    <p>An error occurred while trying to fetch active dynamic instrumentation probes:</p>
    <pre><%= @error %></pre>
    <p>Please check the application logs for more details.</p>
  </div>
<% end %>

<% if @di_status_error %>
  <div class="alert alert-danger">
    <h4><strong>Error Checking DI Status</strong></h4>
    <pre><%= @di_status_error %></pre>
  </div>
<% end %>

<div class="alert alert-info">
  <strong>Debug Info:</strong> Active: <%= @probes.size %>, Disabled: <%= @disabled_probes.size %>, Pending: <%= @pending_probes.size %>, Failed: <%= @failed_probes.size %>
</div>

<% total_probes = @probes.size + @disabled_probes.size + @pending_probes.size + @failed_probes.size %>

<div class="row">
  <div class="col-md-12">
    <% if @probes.empty? && @disabled_probes.empty? && @pending_probes.empty? && @failed_probes.empty? %>
      <div class="alert alert-info">
        <p><strong>No probes found.</strong></p>
        <p><%= probes_empty_state_reason(@di_enabled, @error, @di_unavailable_reason) %></p>
      </div>
    <% end %>

    <% unless @probes.empty? %>
      <h2>Active Probes</h2>
      <p class="lead"><%= pluralize(@probes.count, 'active probe') %></p>

      <div class="panel-group" id="probes-accordion">
        <% @probes.each_with_index do |(id, probe), index| %>
          <div class="panel panel-default">
            <div class="panel-heading">
              <h4 class="panel-title">
                <a data-toggle="collapse" data-parent="#probes-accordion" href="#probe-<%= index %>">
                  <% if probe.file && probe.line_no %>
                    <strong><%= probe.file %>:<%= probe.line_no %></strong>
                  <% elsif probe.type_name && probe.method_name %>
                    <strong><%= probe.type_name %>#<%= probe.method_name %></strong>
                  <% else %>
                    <strong>Probe ID:</strong> <%= id %>
                  <% end %>
                  <span class="badge pull-right"><%= probe.type %></span>
                </a>
              </h4>
            </div>
            <div id="probe-<%= index %>" class="panel-collapse collapse in">
              <div class="panel-body">
                <dl class="dl-horizontal">
                  <dt>Type:</dt>
                  <dd><code><%= probe.type %></code></dd>

                  <% if probe.file %>
                    <dt>File:</dt>
                    <dd><code><%= probe.file %></code></dd>
                  <% end %>

                  <% if probe.line_no %>
                    <dt>Line Number:</dt>
                    <dd><%= probe.line_no %></dd>
                  <% end %>

                  <% if probe.type_name %>
                    <dt>Class/Module:</dt>
                    <dd><code><%= probe.type_name %></code></dd>
                  <% end %>

                  <% if probe.method_name %>
                    <dt>Method:</dt>
                    <dd><code><%= probe.method_name %></code></dd>
                  <% end %>

                  <% if probe.template %>
                    <dt>Template:</dt>
                    <dd><pre><%= probe.template %></pre></dd>
                  <% end %>

                  <% if probe.condition %>
                    <dt>Condition:</dt>
                    <dd><code><%= probe.condition %></code></dd>
                  <% end %>

                  <dt>Rate Limit:</dt>
                  <dd><%= probe.rate_limit %></dd>

                  <%= render 'capture_expressions', probe: probe %>
                </dl>

                <div style="margin-top: 20px;">
                  <strong>Send Status:</strong>
                  <%= button_to 'Emitting', di_status_send_status_path(id), method: :post, params: {status: 'emitting'}, class: 'btn btn-sm btn-info', form: {style: 'display: inline-block; margin-left: 10px;'} %>
                  <%= button_to 'Disabled', di_status_send_status_path(id), method: :post, params: {status: 'disabled'}, class: 'btn btn-sm btn-warning', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                  <%= button_to 'Error', di_status_send_status_path(id), method: :post, params: {status: 'error'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                  <%= button_to 'Error with Exception', di_status_send_status_path(id), method: :post, params: {status: 'error_with_exception'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                </div>

              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% unless @disabled_probes.empty? %>
      <h2 style="margin-top: 30px;">Disabled Probes</h2>
      <p class="lead"><%= pluralize(@disabled_probes.count, 'disabled probe') %></p>

      <div class="panel-group" id="disabled-probes-accordion">
        <% @disabled_probes.each_with_index do |(id, probe), index| %>
          <div class="panel panel-default" style="background-color: #f5f5f5; border-color: #ddd;">
            <div class="panel-heading">
              <h4 class="panel-title">
                <a data-toggle="collapse" data-parent="#disabled-probes-accordion" href="#disabled-probe-<%= index %>">
                  <% if probe.file && probe.line_no %>
                    <strong><%= probe.file %>:<%= probe.line_no %></strong>
                  <% elsif probe.type_name && probe.method_name %>
                    <strong><%= probe.type_name %>#<%= probe.method_name %></strong>
                  <% else %>
                    <strong>Probe ID:</strong> <%= id %>
                  <% end %>
                  <span class="badge pull-right"><%= probe.type %></span>
                </a>
              </h4>
            </div>
            <div id="disabled-probe-<%= index %>" class="panel-collapse collapse in">
              <div class="panel-body">
                <dl class="dl-horizontal">
                  <dt>Type:</dt>
                  <dd><code><%= probe.type %></code></dd>

                  <% if probe.file %>
                    <dt>File:</dt>
                    <dd><code><%= probe.file %></code></dd>
                  <% end %>

                  <% if probe.line_no %>
                    <dt>Line Number:</dt>
                    <dd><%= probe.line_no %></dd>
                  <% end %>

                  <% if probe.type_name %>
                    <dt>Class/Module:</dt>
                    <dd><code><%= probe.type_name %></code></dd>
                  <% end %>

                  <% if probe.method_name %>
                    <dt>Method:</dt>
                    <dd><code><%= probe.method_name %></code></dd>
                  <% end %>

                  <% if probe.template %>
                    <dt>Template:</dt>
                    <dd><pre><%= probe.template %></pre></dd>
                  <% end %>

                  <% if probe.condition %>
                    <dt>Condition:</dt>
                    <dd><code><%= probe.condition %></code></dd>
                  <% end %>

                  <dt>Rate Limit:</dt>
                  <dd><%= probe.rate_limit %></dd>

                  <%= render 'capture_expressions', probe: probe %>
                </dl>

                <div style="margin-top: 20px;">
                  <strong>Send Status:</strong>
                  <%= button_to 'Error', di_status_send_status_path(id), method: :post, params: {status: 'error'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 10px;'} %>
                  <%= button_to 'Error with Exception', di_status_send_status_path(id), method: :post, params: {status: 'error_with_exception'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                </div>

              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% unless @pending_probes.empty? %>
      <h2 style="margin-top: 30px;">Pending Probes</h2>
      <p class="lead"><%= pluralize(@pending_probes.count, 'pending probe') %></p>
      <p class="text-muted">These probes are waiting to be installed in the application.</p>

      <div class="panel-group" id="pending-probes-accordion">
        <% @pending_probes.each_with_index do |(id, probe), index| %>
          <div class="panel panel-warning">
            <div class="panel-heading">
              <h4 class="panel-title">
                <a data-toggle="collapse" data-parent="#pending-probes-accordion" href="#pending-probe-<%= index %>">
                  <% if probe.file && probe.line_no %>
                    <strong><%= probe.file %>:<%= probe.line_no %></strong>
                  <% elsif probe.type_name && probe.method_name %>
                    <strong><%= probe.type_name %>#<%= probe.method_name %></strong>
                  <% else %>
                    <strong>Probe ID:</strong> <%= id %>
                  <% end %>
                  <span class="badge pull-right"><%= probe.type %></span>
                </a>
              </h4>
            </div>
            <div id="pending-probe-<%= index %>" class="panel-collapse collapse in">
              <div class="panel-body">
                <dl class="dl-horizontal">
                  <dt>Type:</dt>
                  <dd><code><%= probe.type %></code></dd>

                  <% if probe.file %>
                    <dt>File:</dt>
                    <dd><code><%= probe.file %></code></dd>
                  <% end %>

                  <% if probe.line_no %>
                    <dt>Line Number:</dt>
                    <dd><%= probe.line_no %></dd>
                  <% end %>

                  <% if probe.type_name %>
                    <dt>Class/Module:</dt>
                    <dd><code><%= probe.type_name %></code></dd>
                  <% end %>

                  <% if probe.method_name %>
                    <dt>Method:</dt>
                    <dd><code><%= probe.method_name %></code></dd>
                  <% end %>

                  <% if probe.template %>
                    <dt>Template:</dt>
                    <dd><pre><%= probe.template %></pre></dd>
                  <% end %>

                  <% if probe.condition %>
                    <dt>Condition:</dt>
                    <dd><code><%= probe.condition %></code></dd>
                  <% end %>

                  <dt>Rate Limit:</dt>
                  <dd><%= probe.rate_limit %></dd>

                  <%= render 'capture_expressions', probe: probe %>
                </dl>

                <div style="margin-top: 20px;">
                  <strong>Send Status:</strong>
                  <%= button_to 'Installed', di_status_send_status_path(id), method: :post, params: {status: 'installed'}, class: 'btn btn-sm btn-success', form: {style: 'display: inline-block; margin-left: 10px;'} %>
                  <%= button_to 'Emitting', di_status_send_status_path(id), method: :post, params: {status: 'emitting'}, class: 'btn btn-sm btn-info', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                  <%= button_to 'Error', di_status_send_status_path(id), method: :post, params: {status: 'error'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                  <%= button_to 'Error with Exception', di_status_send_status_path(id), method: :post, params: {status: 'error_with_exception'}, class: 'btn btn-sm btn-danger', form: {style: 'display: inline-block; margin-left: 5px;'} %>
                </div>

              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% unless @failed_probes.empty? %>
      <h2 style="margin-top: 30px;">Failed Probes</h2>
      <p class="lead"><%= pluralize(@failed_probes.count, 'failed probe') %></p>
      <p class="text-muted">These probes failed to install or encountered errors.</p>

      <div class="panel-group" id="failed-probes-accordion">
        <% @failed_probes.each_with_index do |(id, message), index| %>
          <div class="panel panel-danger">
            <div class="panel-heading">
              <h4 class="panel-title">
                <a data-toggle="collapse" data-parent="#failed-probes-accordion" href="#failed-probe-<%= index %>">
                  <strong>Probe ID:</strong> <%= id %>
                </a>
              </h4>
            </div>
            <div id="failed-probe-<%= index %>" class="panel-collapse collapse in">
              <div class="panel-body">
                <dl class="dl-horizontal">
                  <dt>Probe ID:</dt>
                  <dd><code><%= id %></code></dd>

                  <dt>Error:</dt>
                  <dd><pre><%= message %></pre></dd>
                </dl>

              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
