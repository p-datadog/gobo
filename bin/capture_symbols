#!/usr/bin/env bash
#
# bin/capture_symbols
#
# Runs a mock agent that captures the symdb upload payload,
# decompresses it, and pretty-prints the JSON.
#
# Usage:
#   # Terminal 1: start the capture server
#   bin/capture_symbols
#
#   # Terminal 2: run extract_symbols pointing at the capture server
#   DD_TRACE_AGENT_PORT=8877 bin/extract_symbols

set -euo pipefail

CAPTURE_PORT="${CAPTURE_PORT:-8877}"
CAPTURE_DIR="/tmp/symdb_captures"
mkdir -p "$CAPTURE_DIR"

echo "Starting symdb capture server on port $CAPTURE_PORT"
echo "Captures saved to: $CAPTURE_DIR"
echo ""
echo "Run in another terminal:"
echo "  cd $(pwd) && ${DD_TRACER:+DD_TRACER=$DD_TRACER }DD_TRACE_AGENT_PORT=$CAPTURE_PORT bin/extract_symbols"
echo ""
echo "Press Ctrl+C to stop."
echo ""

bundle exec ruby -e '
require "webrick"
require "json"
require "zlib"
require "fileutils"

capture_dir = ENV.fetch("CAPTURE_DIR", "/tmp/symdb_captures")
capture_port = ENV.fetch("CAPTURE_PORT", "8877").to_i
request_count = 0

server = WEBrick::HTTPServer.new(Port: capture_port, Logger: WEBrick::Log.new("/dev/null"), AccessLog: [])

# Accept any request the tracer sends during init (info, telemetry, traces, etc.)
server.mount_proc "/" do |req, res|
  if req.path == "/symdb/v1/input" && req.request_method == "POST"
    request_count += 1
    timestamp = Time.now.strftime("%H%M%S")

    # Parse multipart body using WEBrick's built-in parser.
    # Manual body.split parsing fails silently on binary gzip data due to encoding errors.
    # req.query handles multipart/form-data correctly for both text and binary parts.
    form_data = req.query

    # Save raw request body for debugging
    raw_body = req.body || ""
    raw_path = File.join(capture_dir, "#{timestamp}_#{request_count}_raw.bin")
    File.binwrite(raw_path, raw_body)

    # Event metadata part (field name: "event")
    if (event_part = form_data["event"])
      event_str = event_part.to_s
      event_path = File.join(capture_dir, "#{timestamp}_#{request_count}_event.json")
      File.write(event_path, event_str)
      parsed = JSON.parse(event_str) rescue event_str
      puts "=== Upload ##{request_count} — Event metadata ==="
      puts JSON.pretty_generate(parsed) rescue puts(event_str)
      puts ""
    end

    # Symbols gzip part (field name: "file")
    if (file_part = form_data["file"])
      begin
        gzip_data = file_part.to_s.b  # force binary encoding for Zlib
        json_data = Zlib.gunzip(gzip_data)
        symbols_path = File.join(capture_dir, "#{timestamp}_#{request_count}_symbols.json")
        File.write(symbols_path, json_data)
        parsed = JSON.parse(json_data)

        puts "=== Upload ##{request_count} — Symbols payload ==="
        puts "  service:  #{parsed["service"]}"
        puts "  env:      #{parsed["env"]}"
        puts "  version:  #{parsed["version"]}"
        puts "  language: #{parsed["language"]}"
        puts "  scopes:   #{parsed["scopes"]&.size || 0}"
        puts ""

        parsed["scopes"]&.each do |scope|
          puts "  [#{scope["scope_type"]}] #{scope["name"]}"
          puts "    source: #{scope["source_file"]}:#{scope["start_line"]}-#{scope["end_line"]}"
          scope["scopes"]&.each do |child|
            puts "    [#{child["scope_type"]}] #{child["name"]}"
            child["symbols"]&.each do |sym|
              puts "      #{sym["symbol_type"]}: #{sym["name"]} (line #{sym["line"]})"
            end
          end
          scope["symbols"]&.each do |sym|
            puts "    #{sym["symbol_type"]}: #{sym["name"]} (line #{sym["line"]})"
          end
          puts ""
        end

        # Also save pretty-printed version
        pretty_path = File.join(capture_dir, "#{timestamp}_#{request_count}_symbols_pretty.json")
        File.write(pretty_path, JSON.pretty_generate(parsed))
      rescue Zlib::GzipFile::Error => e
        puts "=== Upload ##{request_count} — Could not decompress: #{e} ==="
      end
    end

    res.status = 200
    res.body = "{}"
  else
    # Accept everything else (traces, telemetry, info, etc.)
    res.status = 200
    res.body = case req.path
    when "/info"
      "{\"endpoints\":[\"/symdb/v1/input\"],\"client_drop_p0s\":true}"
    when %r{/v0\.\d+/traces}
      "{}"
    else
      "{}"
    end
  end
end

trap("INT") { server.shutdown }
server.start
'
