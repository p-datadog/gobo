#!/bin/sh
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
GOBO_DIR="$(dirname "$SCRIPT_DIR")"
IMAGE="gobo-locust"
REPO_HTTPS="https://github.com/p-datadog/locust.git"
REPO_SSH="git@github.com:p-datadog/locust.git"
REBUILD=""
HOST=""

while getopts "r" opt; do
  case $opt in
    r) REBUILD=1 ;;
    *) echo "Usage: $0 [-r] [host]"; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

HOST="${1:-http://localhost:3000}"

if [ -n "$REBUILD" ]; then
  docker rmi "$IMAGE" 2>/dev/null || true
fi

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "Building $IMAGE..."
  BUILD_DIR=$(mktemp -d /tmp/gobo-locust-build.XXXXXX)
  chmod 700 "$BUILD_DIR"
  trap "rm -rf $BUILD_DIR" EXIT
  if ! GIT_TERMINAL_PROMPT=0 git clone --depth 1 "$REPO_HTTPS" "$BUILD_DIR/locust" 2>/dev/null; then
    echo "HTTPS clone failed, trying SSH..."
    git clone --depth 1 "$REPO_SSH" "$BUILD_DIR/locust"
  fi
  docker build -t "$IMAGE" "$BUILD_DIR/locust"
fi

TMPFILE=$(mktemp /tmp/locustfile.XXXXXX.py)
cp "$GOBO_DIR/locustfile.py" "$TMPFILE"
chmod 644 "$TMPFILE"

# --network=host shares the host network stack so localhost:3000 reaches gobo
# directly. Bridge networking requires firewall rules for container-to-host traffic.
exec docker run --rm -it \
  --network=host \
  -v "$TMPFILE:/home/locust/locustfile.py:ro" \
  "$IMAGE" \
  -f /home/locust/locustfile.py --host="$HOST"
