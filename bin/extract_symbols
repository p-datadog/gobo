#!/usr/bin/env ruby
#
# bin/extract_symbols
#
# Boots the Rails app to extract and upload symbols from demo-ruby to Datadog.
# Requires a Datadog agent running on localhost:8126.
#
# Usage:
#   bin/extract_symbols
#   DD_TRACER=/real.home/claude-2/dtr bin/extract_symbols   # local tracer build
#   DD_TRACE_DEBUG=true bin/extract_symbols                 # verbose logging

if ARGV.include?("-h") || ARGV.include?("--help")
  puts File.read(__FILE__).lines[1..11].map { |l| l.sub(/^# ?/, "") }.join
  exit 0
end

ENV["DD_SYMBOL_DATABASE_UPLOAD_ENABLED"] ||= "true"
ENV["DD_INTERNAL_FORCE_SYMBOL_DATABASE_UPLOAD"] ||= "true"
ENV["DD_DYNAMIC_INSTRUMENTATION_ENABLED"] ||= "true"
ENV["DD_TRACE_DEBUG"] ||= "false"
ENV["DD_TRACE_LOG_LEVEL"] ||= "warn"

ENV["DD_SERVICE"] ||= "ruby-symdb-test"
ENV["DD_ENV"] ||= "development"
ENV["DD_VERSION"] ||= "1.0"

puts "Symbol extraction from demo-ruby"
puts "  Tracer:  #{ENV['DD_TRACER'] || 'datadog gem (release)'}"
puts "  Agent:   #{ENV['DD_AGENT_HOST'] || 'localhost'}:#{ENV['DD_TRACE_AGENT_PORT'] || '8126'}"
puts "  Service: #{ENV['DD_SERVICE']} (#{ENV['DD_ENV']})"
puts ""

APP_PATH = File.expand_path("../config/application", __dir__)
require_relative "../config/environment"

Rails.application.eager_load!

puts "Rails loaded. Classes available for extraction:"
puts "  Models:      #{ApplicationRecord.descendants.map(&:name).compact.sort.join(', ')}"
puts "  Controllers: #{ApplicationController.descendants.map(&:name).compact.sort.join(', ')}"
puts ""

components = Datadog.send(:components)
unless components.respond_to?(:symbol_database)
  abort "ERROR: This version of datadog gem does not support symbol_database.\n" \
        "  Use bin/use-tracer to point at a build that includes symdb support."
end

symdb = components.symbol_database
if symdb
  puts "Triggering symbol extraction..."
  symdb.start_upload
else
  puts "WARNING: symbol_database component is nil -- check DD_SYMBOL_DATABASE_* env vars"
end

puts "Waiting for upload to complete..."
sleep 5
puts "Done."
